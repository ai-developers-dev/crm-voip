# VoIP CRM — Production environment variables
# Copy to .env.local and fill in all values before running the app.

# ─── Convex ────────────────────────────────────────────────
# Get these from https://dashboard.convex.dev
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_SITE_URL=https://your-deployment.convex.site
CONVEX_DEPLOYMENT=your-deployment-id

# ─── Clerk Authentication ──────────────────────────────────
# Get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
CLERK_JWT_ISSUER_DOMAIN=your-app.clerk.accounts.dev
CLERK_ISSUER_URL=https://your-app.clerk.accounts.dev

# ─── App URL ───────────────────────────────────────────────
# MUST be the public HTTPS URL in production (never localhost).
# Used for Twilio callback URLs, e-sign links, email CTAs.
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ─── Credential Encryption ────────────────────────────────
# 64 hex characters (32 bytes). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Used to encrypt per-tenant Twilio auth tokens at rest.
# DO NOT rotate once tenants have encrypted data — you will lose it.
CREDENTIAL_ENCRYPTION_KEY=

# ─── Twilio (platform fallback) ───────────────────────────
# Used when a tenant hasn't configured their own subaccount.
# Tenants with their own encrypted credentials take precedence.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ─── Nylas (Email + Calendar) ─────────────────────────────
# Get these from https://dashboard-v3.nylas.com
NYLAS_CLIENT_ID=
NYLAS_API_KEY=nyk_v0_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NYLAS_API_URI=https://api.us.nylas.com
NYLAS_WEBHOOK_SECRET=

# ─── Retell AI (Optional, for AI voice agents) ────────────
# Webhook secret is required in production if Retell is used.
# Leave unset to disable AI voice features.
# RETELL_WEBHOOK_SECRET=

# ─── Stripe (Optional, for billing) ───────────────────────
# Used for platform billing. Not required for core calling.
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx

# ─── OpenAI (Optional, for AI SMS/email features) ─────────
# Used by the SMS AI responder.
# OPENAI_API_KEY=sk-xxx
